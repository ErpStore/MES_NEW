<Window x:Class="MES.Presentation.UI.Modules.UserManagement.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:common="clr-namespace:MES.Presentation.UI.Common"
        mc:Ignorable="d"
        Title="User LogIn"
        Height="480" Width="320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#EFEFEF" BorderBrush="#001C3B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#001C3B">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="User LogIn"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <Button Grid.Column="1"
                        Command="{Binding LogoutCommand}"
                        Content="X"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="30"
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </Grid>

            <!-- App Banner -->
            <Border Grid.Row="1" Background="#FFCC00" Margin="8,8,8,0" CornerRadius="4">
                <Grid Margin="10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo placeholder -->
                    <Border Width="44" Height="44" Background="#001C3B" CornerRadius="22" Margin="0,0,10,0">
                        <TextBlock Text="T" Foreground="#FFCC00" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="EnJoin MES-" Foreground="#001C3B" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="Manual chemical System" Foreground="#001C3B" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search Box -->
            <Grid Grid.Row="2" Margin="8,6,8,0">
                <TextBox Style="{StaticResource SearchTextBox}"
                         Height="30"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <!-- User List -->
            <Border Grid.Row="3" Margin="8,4,8,0" Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
                <ListBox ItemsSource="{Binding Users}"
                         SelectedItem="{Binding SelectedUser}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFCC00"/>
                                    <Setter Property="Foreground" Value="#001C3B"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F2F2F2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- User icon -->
                                <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16,14 20,16 20,18V20H4V18C4,16 8,14 12,14Z"
                                      Fill="#001C3B"
                                      Width="18" Height="18"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding UserName}" Foreground="#666" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Password Row -->
            <Grid Grid.Row="4" Margin="8,6,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                      Fill="#666"
                      Width="18" Height="18"
                      Stretch="Uniform"
                      VerticalAlignment="Center"
                      Margin="4,0,6,0"/>
                <PasswordBox Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Padding="6,0"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             common:PasswordBoxHelper.BindPassword="True"
                             common:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Error Message + Buttons -->
            <Grid Grid.Row="5" Margin="8,0,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="#D32F2F"
                           FontSize="11"
                           Margin="0,2,0,2"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Width="80" Height="28"
                            Background="#555"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="0"/></Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Login"
                            Command="{Binding LoginCommand}"
                            Width="80" Height="28"
                            Background="#001C3B"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="0"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
