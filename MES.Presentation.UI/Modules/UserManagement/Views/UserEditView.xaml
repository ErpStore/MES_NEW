<Window x:Class="MES.Presentation.UI.Modules.UserManagement.Views.UserEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="520" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        xmlns:common="clr-namespace:MES.Presentation.UI.Common">

    <Border Background="#F0F0F0" BorderBrush="#001C3B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#001C3B">
                <TextBlock Text="{Binding WindowTitle}" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="10,0,0,0" 
                           FontSize="14"/>

                <Button Command="{Binding CancelCommand}"
                        Content="X"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        Width="30"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource PopUpLabelStyle}">
                    <Run Text="★" Foreground="Black" FontSize="10" BaselineAlignment="Top"/>
                    <Run Text="User Name"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Style="{StaticResource PopUpTextBoxStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="First Name"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FirstName}"
                         Style="{StaticResource PopUpTextBoxStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Name"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding LastName}"
                         Style="{StaticResource PopUpTextBoxStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Style="{StaticResource PopUpLabelStyle}">
                    <Run Text="★" Foreground="Black" FontSize="10" BaselineAlignment="Top"/>
                    <Run Text="Departments"/>
                </TextBlock>
                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Departments}" 
                          SelectedItem="{Binding SelectedDepartment, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                          Style="{StaticResource PopUpComboBoxStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Email"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Email}"
                         Style="{StaticResource PopUpTextBoxStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Mobile"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Mobile}"
                         Style="{StaticResource PopUpTextBoxStyle}"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Enable password expiry"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding EnablePasswordExpiry}" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Password expiry date"
                           Style="{StaticResource PopUpLabelStyle}"/>
                <DatePicker Grid.Row="9" Grid.Column="1" SelectedDate="{Binding PasswordExpiryDate}" IsEnabled="{Binding EnablePasswordExpiry}"/>

                <TextBlock Grid.Row="11" Grid.Column="0"
                           Style="{StaticResource PopUpLabelStyle}">
                    <Run Text="★" Foreground="Black" FontSize="10" BaselineAlignment="Top"/>
                    <Run Text="Enter Password"/>
                </TextBlock>
                <PasswordBox Grid.Row="11" Grid.Column="1"
                 common:PasswordBoxHelper.BindPassword="True"
                 common:PasswordBoxHelper.BoundPassword="{Binding PasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="12" Grid.Column="0"
                           Style="{StaticResource PopUpLabelStyle}">
                    <Run Text="★" Foreground="Black" FontSize="10" BaselineAlignment="Top"/>
                    <Run Text="Confirmation Password"/>
                </TextBlock>
                <PasswordBox Grid.Row="12" Grid.Column="1"
                 common:PasswordBoxHelper.BindPassword="True"
                 common:PasswordBoxHelper.BoundPassword="{Binding ConfirmPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            
            <Grid Grid.Row="2" Background="#F0F0F0">
                <Button Content="Accept" 
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="100" Height="30"
                        Margin="0,0,20,0"
                        Background="#001C3B"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"/>
            </Grid>

        </Grid>
    </Border>
</Window>