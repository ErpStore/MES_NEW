<Window x:Class="MES.Presentation.UI.Modules.UserManagement.Views.UserGroupEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MES.Presentation.UI.Modules.UserManagement.Views"
             mc:Ignorable="d" 
             WindowStartupLocation="CenterOwner"
             WindowStyle="None" ResizeMode="NoResize"
             AllowsTransparency="True" Background="Transparent"
             Height="200" Width="400"
             Title="{Binding WindowTitle}">
    <Border Background="{StaticResource LightWhiteBrush}" BorderBrush="{StaticResource PrimaryBrandBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#001C3B">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding WindowTitle, FallbackValue='Add Group'}" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="10,0,0,0" 
                           FontSize="12"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="1" 
                        Command="{Binding CancelCommand}"
                        Content="X" 
                        Foreground="White" 
                        Background="Transparent" 
                        BorderThickness="0"
                        Width="30" 
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" VerticalAlignment="Center" Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" 
                           Margin="0,0,10,0" Foreground="#333">
                    <Run Text="★" Foreground="#001C3B" FontSize="10" BaselineAlignment="Top"/>
                    <Run Text="User Group"/>
                </TextBlock>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Height="25" 
                         VerticalContentAlignment="Center"
                         BorderBrush="#CCCCCC"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Description"
                           VerticalAlignment="Center" HorizontalAlignment="Right" 
                           Margin="0,0,10,0" Foreground="#333"/>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="25" 
                         VerticalContentAlignment="Center"
                         BorderBrush="#CCCCCC"/>
            </Grid>

            <Grid Grid.Row="2" Background="Transparent" Margin="0,0,20,10">
                <Button Content="Accept" 
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Bottom"
                        Width="80" Height="25"
                        Background="#001C3B" 
                        Foreground="White" 
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>
