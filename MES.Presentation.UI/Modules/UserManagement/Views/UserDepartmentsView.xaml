<UserControl x:Class="MES.Presentation.UI.Modules.UserManagement.Views.UserDepartmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="White">
        <DataGrid ItemsSource="{Binding UserGroups}"
                  SelectedItem="{Binding SelectedGroup}"
                  Style="{StaticResource IndustrialDataGridStyle}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditGroupCommand}"/>
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>

                <DataGridTextColumn Header="User Group Name" 
                                    Binding="{Binding Name}" 
                                    Width="250"
                                    FontWeight="SemiBold"/>

                <DataGridTextColumn Header="Description" 
                                    Binding="{Binding Description}" 
                                    Width="*"/>

                <DataGridTemplateColumn Header="Actions" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                                <Button Command="{Binding DataContext.EditGroupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Edit User Group"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                                    <TextBlock Text="✎" FontSize="16" Foreground="#001C3B" FontWeight="Bold"/>
                                </Button>

                                <Button Command="{Binding DataContext.ManageRightsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Manage Rights"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                                    <TextBlock Text="🔑" FontSize="14"/>
                                </Button>

                                <Button Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Delete User Group"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="🗑" FontSize="16" Foreground="#D32F2F"/>
                                </Button>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Grid>
</UserControl>
