<UserControl x:Class="MES.Presentation.UI.Modules.UserManagement.Views.UserRightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MES.Presentation.UI.Modules.UserManagement.Views"
             mc:Ignorable="d"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Column Headers -->
        <Border Grid.Row="0" Background="#001C3B">
            <DockPanel LastChildFill="True">
                <!-- DELETE header – docked right first so it ends up rightmost -->
                <Border DockPanel.Dock="Right" Width="70"
                        BorderBrush="#1A3A5C" BorderThickness="1,0,0,0">
                    <Border.Background>
                        <SolidColorBrush Color="#001C3B"/>
                    </Border.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="#C62828" CornerRadius="2"
                                Padding="6,1" Margin="0,0,0,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="DELETE"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Remove records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- EDIT header -->
                <Border DockPanel.Dock="Right" Width="70"
                        BorderBrush="#1A3A5C" BorderThickness="1,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="#1565C0" CornerRadius="2"
                                Padding="6,1" Margin="0,0,0,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="EDIT"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Modify records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ADD header -->
                <Border DockPanel.Dock="Right" Width="70"
                        BorderBrush="#1A3A5C" BorderThickness="1,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="#2E7D32" CornerRadius="2"
                                Padding="6,1" Margin="0,0,0,2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="ADD"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Create records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Title label fills remaining left space -->
                <TextBlock Text="Assignable Authorization"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Rights Tree -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="White"
                      BorderBrush="#DDDDDD"
                      BorderThickness="1">
            <TreeView ItemsSource="{Binding RightNodes}"
                      Background="Transparent"
                      BorderThickness="0">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="2,3"/>
                    </Style>
                </TreeView.Resources>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <DockPanel MinHeight="24" LastChildFill="True">
                            <!-- Checkbox panel docked to right; total width 210 px = 3 × 70
                                 This matches the three 70-px header columns exactly so that
                                 the checkboxes stay aligned regardless of tree indentation. -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Width="210"
                                        Visibility="{Binding IsLeaf, Converter={StaticResource BoolToVisibility}}">
                                <!-- ADD -->
                                <Border Width="70" BorderBrush="#EEEEEE" BorderThickness="1,0,0,0">
                                    <CheckBox IsChecked="{Binding CanAdd, Mode=TwoWay}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <!-- EDIT -->
                                <Border Width="70" BorderBrush="#EEEEEE" BorderThickness="1,0,0,0">
                                    <CheckBox IsChecked="{Binding CanEdit, Mode=TwoWay}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <!-- DELETE -->
                                <Border Width="70" BorderBrush="#EEEEEE" BorderThickness="1,0,0,0">
                                    <CheckBox IsChecked="{Binding CanDelete, Mode=TwoWay}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>
    </Grid>
</UserControl>
