<UserControl x:Class="MES.Presentation.UI.Modules.UserManagement.Views.UserRightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <!-- User selector row (admin only) -->
            <RowDefinition Height="Auto"/>
            <!-- Column header row -->
            <RowDefinition Height="48"/>
            <!-- Rights tree -->
            <RowDefinition Height="*"/>
            <!-- Save button row (admin only) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- User Selector (visible only for admin) -->
        <Border Grid.Row="0"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Select User:"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#333333"/>
                <ComboBox ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                          Width="220"
                          Height="26"
                          FontSize="11">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run  Text="{Binding FullName, Mode=OneWay}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding UserName}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="#001C3B">
            <DockPanel LastChildFill="True">

                <!-- DELETE header (dock right first → rightmost column) -->
                <Border DockPanel.Dock="Right"
                        Width="100"
                        BorderBrush="#1A3A5C"
                        BorderThickness="1,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4">
                        <Border Background="#C62828" CornerRadius="3"
                                Padding="8,2" Margin="0,0,0,3"
                                HorizontalAlignment="Center">
                            <TextBlock Text="DELETE"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Remove records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- EDIT header -->
                <Border DockPanel.Dock="Right"
                        Width="100"
                        BorderBrush="#1A3A5C"
                        BorderThickness="1,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4">
                        <Border Background="#1565C0" CornerRadius="3"
                                Padding="8,2" Margin="0,0,0,3"
                                HorizontalAlignment="Center">
                            <TextBlock Text="EDIT"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Modify records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ADD header -->
                <Border DockPanel.Dock="Right"
                        Width="100"
                        BorderBrush="#1A3A5C"
                        BorderThickness="1,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4">
                        <Border Background="#2E7D32" CornerRadius="3"
                                Padding="8,2" Margin="0,0,0,3"
                                HorizontalAlignment="Center">
                            <TextBlock Text="ADD"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Create records"
                                   Foreground="#AAAAAA"
                                   FontSize="8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Title label -->
                <TextBlock Text="Assignable Authorization"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Rights Tree -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="White"
                      BorderBrush="#DDDDDD"
                      BorderThickness="1">
            <TreeView ItemsSource="{Binding RightNodes}"
                      Background="Transparent"
                      BorderThickness="0">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="2,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </TreeView.Resources>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <DockPanel MinHeight="28" LastChildFill="True">

                            <!-- DELETE checkbox (dock right first → rightmost) -->
                            <Border DockPanel.Dock="Right"
                                    Width="100"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1,0,0,0"
                                    Background="Transparent">
                                <CheckBox IsChecked="{Binding CanDelete, Mode=TwoWay}"
                                          IsEnabled="{Binding DataContext.IsAdmin,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsLeaf, Converter={StaticResource BoolToVisibility}}"/>
                            </Border>

                            <!-- EDIT checkbox -->
                            <Border DockPanel.Dock="Right"
                                    Width="100"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1,0,0,0"
                                    Background="Transparent">
                                <CheckBox IsChecked="{Binding CanEdit, Mode=TwoWay}"
                                          IsEnabled="{Binding DataContext.IsAdmin,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsLeaf, Converter={StaticResource BoolToVisibility}}"/>
                            </Border>

                            <!-- ADD checkbox -->
                            <Border DockPanel.Dock="Right"
                                    Width="100"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1,0,0,0"
                                    Background="Transparent">
                                <CheckBox IsChecked="{Binding CanAdd, Mode=TwoWay}"
                                          IsEnabled="{Binding DataContext.IsAdmin,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsLeaf, Converter={StaticResource BoolToVisibility}}"/>
                            </Border>

                            <!-- Node name (fills remaining space) -->
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="2,0,6,0"/>
                        </DockPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>

        <!-- Save button (admin only) -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0"
                Padding="8,6"
                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
            <Button Content="Save Rights"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Right"
                    Width="100" Height="28"
                    Background="#001C3B"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    FontSize="11"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="2"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</UserControl>
