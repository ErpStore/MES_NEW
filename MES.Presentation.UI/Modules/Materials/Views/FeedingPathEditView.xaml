<Window x:Class="MES.Presentation.UI.Modules.Materials.Views.FeedingPathEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MES.Presentation.UI.Modules.Materials.Views"
        mc:Ignorable="d"
        Title="FeedingPathEditView" Height="380" Width="650"
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        AllowsTransparency="True" 
        Background="Transparent">
    <Border Background="{StaticResource LightWhiteBrush}" BorderBrush="#001C3B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}">
                <TextBlock Text="{Binding WindowTitle}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                <Button Command="{Binding CancelCommand}" Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Width="30" FontWeight="Bold" Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Run Text="★" Foreground="#001C3B" FontSize="10" BaselineAlignment="Top"/><Run Text=" Bin Number"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BinNumber, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Run Text="★" Foreground="#001C3B" FontSize="10" BaselineAlignment="Top"/><Run Text=" Bin Code"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding BinCode, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Run Text="★" Foreground="#001C3B" FontSize="10" BaselineAlignment="Top"/><Run Text=" Material"/>
                </TextBlock>

                <ComboBox Grid.Row="1" Grid.Column="1" Height="25" VerticalContentAlignment="Center"
                          ItemsSource="{Binding Materials}"
                          SelectedItem="{Binding SelectedMaterial}">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black" />
                            <Setter Property="Background" Value="White" />
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialCode, FallbackValue='NO CODE', TargetNullValue='NULL'}" 
                                       Foreground="Black" Margin="2,0"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Run Text="★" Foreground="#001C3B" FontSize="10" BaselineAlignment="Top"/><Run Text=" Max Capacity (kg)"/>
                </TextBlock>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding MaxCapacity, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Stock (kg)" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CurrentStock, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Filled Date" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <DatePicker Grid.Row="2" Grid.Column="4" SelectedDate="{Binding FilledDate, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expiry Date" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Description" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,10,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="50" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True"/>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,20,10">
                <Button Content="Accept" Command="{Binding SaveCommand}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="80" Height="25" Background="#001C3B" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
