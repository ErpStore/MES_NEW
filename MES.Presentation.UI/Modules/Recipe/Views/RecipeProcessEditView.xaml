<Window x:Class="MES.Presentation.UI.Modules.Recipe.Views.RecipeProcessEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="350" Width="600"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent">
    <Border Background="#F5F5F5" BorderBrush="#001C3B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#001C3B">
                <TextBlock Text="{Binding WindowTitle}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                <Button Command="{Binding CancelCommand}" Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Width="30" FontWeight="Bold" Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="S.No." VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SerialNumber}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Material" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <ComboBox Grid.Row="0" Grid.Column="4" Height="25" VerticalContentAlignment="Center" ItemsSource="{Binding Materials}" SelectedItem="{Binding SelectedMaterial}">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="Background" Value="White"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MaterialCode}" Foreground="Black"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Weight (kg)" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Weight}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Tol (+)" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding TolerancePositive}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Tol (-)" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding ToleranceNegative}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Description" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,10,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding Description}" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,20,10">
                <Button Content="Accept" Command="{Binding SaveCommand}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="80" Height="25" Background="#001C3B" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
            </Grid>
        </Grid>
    </Border>
</Window>
