<UserControl x:Class="MES.Presentation.UI.Controls.HeaderBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MES.Presentation.UI.Controls" xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DesignHeight="60">
    <Grid Background="{StaticResource PrimaryBrandBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- APP TITLE -->
        <svgc:SvgViewbox Width="100" Height="100" Source="Assert/TrikalaName.svg" 
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         Margin="5,0"
                         RenderOptions.BitmapScalingMode="HighQuality"
                         SnapsToDevicePixels="True"/>

        <Grid Grid.Column="1" Background="{StaticResource PrimaryBrandBrush}" Height="40">
            <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                Margin="0,0,20,10">

                <TextBlock Text="{Binding CurrentDateTime}" 
                   Foreground="White" 
                   VerticalAlignment="Center" 
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="10,0"/>

                <Border Width="1" 
                Background="White" 
                Height="20" 
                VerticalAlignment="Center" 
                Margin="5,0"/>

                <StackPanel Orientation="Horizontal" Margin="15,0,0,0">
                    <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16,14 20,16 20,18V20H4V18C4,16 8,14 12,14Z" 
                  Fill="White" 
                  Width="18" 
                  Height="18" 
                  Stretch="Uniform" 
                  VerticalAlignment="Center" 
                  Margin="0,0,8,0"/>

                    <TextBlock Text="{Binding UserName}" 
                       Foreground="White" 
                       VerticalAlignment="Center" 
                       FontWeight="Bold"
                       FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
