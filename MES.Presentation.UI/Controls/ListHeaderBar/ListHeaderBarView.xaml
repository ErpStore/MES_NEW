<UserControl x:Class="MES.Presentation.UI.Controls.ListHeaderBar.ListHeaderBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MES.Presentation.UI.Controls.ListHeaderBar"
             mc:Ignorable="d"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT: TABS ================= -->
        <TabControl ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <TextBlock Text=""
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            VerticalAlignment="Center"
            Margin="8">

            <Button Command="{Binding RefreshCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Refresh.svg" />
            </Button>

            <Button Command="{Binding AddCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Add.svg" />
            </Button>
            
            <Button Command="{Binding DeleteCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Delete.svg" />
            </Button>

            <Button Command="{Binding CopyCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Copy.svg" />
            </Button>            
            
            <Button Command="{Binding PasteCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Paste.svg" />
            </Button>            
            
            <Button Command="{Binding PrintCommand}" Style="{StaticResource TransparentIconButton}">
                <svgc:SvgViewbox Width="18" Height="18" Source="Assert/Print.svg" />
            </Button>

            <TextBox Width="160"
             Height="28"
             Margin="8,0,0,0"
             Style="{StaticResource SearchTextBox}"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
    </Grid>
</UserControl>
